# The compose file defaults to the local image name built from this repository.
# Point this at your forked registry image only when you publish one, for example:
# ZEEBE_PLAY_IMAGE=ghcr.io/camundaguru/zeebe-play:2.0.0-SNAPSHOT
ZEEBE_PLAY_IMAGE=zeebe-play:2.0.0-SNAPSHOT

# Used by docker-compose.local-build.yml.
ZEEBE_PLAY_JAR=target/zeebe-play-2.0.0-SNAPSHOT.jar

# Keep the remote-engine broker on the Camunda version used by the Maven build.
# Override this if you publish/use a custom Zeebe image with the Hazelcast exporter baked in.
ZEEBE_BROKER_IMAGE=camunda/zeebe:8.9.0

# Created by `mvn -DskipTests package`.
ZEEBE_HAZELCAST_EXPORTER_JAR=../target/docker/zeebe-hazelcast-exporter.jar

POSTGRES_IMAGE=postgres:12.2
MYSQL_IMAGE=mysql:8
